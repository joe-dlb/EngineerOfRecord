<!--  ARCHITECTURE & PITCH                                              -->
<!-- ═══════════════════════════════════════════════════════════════════ -->

<div class="demo-page" style="margin-top: 48px">

    <section class="doc-section">
        <h1 class="section-heading">Software Architecture</h1>
        <p class="section-desc">
            How the EOR application is structured, why we made specific design decisions,
            and how data flows between our database and Vantagepoint.
        </p>

        <h2 class="sub-heading">Three Pillars</h2>
        <div class="pillars-grid">
            <div class="pillar-card">
                <div class="pillar-num">1</div>
                <h3>Domain Model</h3>
                <p>
                    Plain C# classes that represent the business concepts &mdash; <code>EngineerOfRecord</code>,
                    <code>Employee</code>, <code>Discipline</code>, <code>UsState</code>. No database annotations, no framework dependencies.
                    The domain layer has zero NuGet packages. It's pure business logic that anyone can read.
                </p>
            </div>
            <div class="pillar-card">
                <div class="pillar-num">2</div>
                <h3>EF Core Persistence</h3>
                <p>
                    A <code>DbContext</code> that maps domain entities to SQL Server tables. Configuration is in C#, schema
                    changes are versioned as migrations, and the database is created automatically on first run.
                    No stored procedures. No database project. No DACPAC deployments.
                </p>
            </div>
            <div class="pillar-card">
                <div class="pillar-num">3</div>
                <h3>Vantagepoint Sync</h3>
                <p>
                    All active employees are copied from Vantagepoint into a local Employee table and kept in sync.
                    This makes our app Vantagepoint-agnostic at query time &mdash; if VP goes down,
                    the EOR app still works with the last-synced data.
                </p>
            </div>
        </div>

        <h2 class="sub-heading">Data Ownership: Local Copy vs. Database Views</h2>
        <p>
            The core challenge is that an <code>EngineerOfRecord</code> combines data from two sources:
            our custom fields (discipline, license, states) and Vantagepoint fields (name, email, title).
            These two approaches were evaluated:
        </p>

        <div class="comparison-grid">
            <div class="comparison-card rejected">
                <h3>Option A: Database Views <span class="badge badge-red">Rejected</span></h3>
                <p>Create a SQL view that JOINs our table to <code>Vantagepoint_DevOps.dbo.EM</code>. Configure
                EF Core with <code>ToTable()</code> for writes and <code>ToView()</code> for reads.</p>
                <div class="pros-cons">
                    <div class="pro">Single query returns hydrated data</div>
                    <div class="pro">No sync service needed</div>
                    <div class="con">Runtime dependency on Vantagepoint &mdash; if VP is down, our reads break</div>
                    <div class="con">Cross-database JOINs can't be indexed from our side</div>
                    <div class="con">View lives outside EF Core migrations &mdash; cracks the "everything is code" story</div>
                    <div class="con">Complex <code>PropertySaveBehavior.Ignore</code> config for read-only VP columns</div>
                </div>
                <div class="code-block">
                    <div class="code-label">What it would look like in DbContext</div>
                    <pre><code>// Reads from view, writes to table
entity.ToTable("EngineerOfRecord");
entity.ToView("vw_EngineerOfRecord");

// Each VP field needs this to prevent EFC
// from including it in INSERT/UPDATE statements
entity.Property(x => x.EmployeeName)
    .ValueGeneratedOnAddOrUpdate()
    .Metadata.SetBeforeSaveBehavior(
        PropertySaveBehavior.Ignore);</code></pre>
                </div>
            </div>

            <div class="comparison-card accepted">
                <h3>Option B: Local Copy + Sync <span class="badge badge-green">Chosen</span></h3>
                <p>Copy all VP employees into a local <code>Employee</code> table. <code>EngineerOfRecord</code> has a FK
                to <code>Employee</code> — clean separation, no duplicated fields.</p>
                <div class="pros-cons">
                    <div class="pro">One database, one DbContext, standard EF Core mapping &mdash; no tricks</div>
                    <div class="pro">App works even if Vantagepoint is down (uses last-synced data)</div>
                    <div class="pro">If DLB ever migrates off Vantagepoint, only the sync service changes</div>
                    <div class="pro">Testing is trivial &mdash; seed test DB, no VP mock needed</div>
                    <div class="con">Data is duplicated (employee names in two places)</div>
                    <div class="con">Brief staleness window between VP change and next sync</div>
                </div>
                <div class="code-block">
                    <div class="code-label">Two tables, one relationship</div>
                    <pre><code>// Employee table — synced from VP, all active employees
public class Employee {
    public string VantagepointEmployeeId { get; init; } // PK
    public string FirstName { get; set; }
    public string LastName { get; set; }
    public string Email { get; set; }
    public string Title { get; set; }
}

// EOR table — pure domain data, FK to Employee
public class EngineerOfRecord {
    public Guid Id { get; private set; }
    public string VantagepointEmployeeId { get; init; } // FK
    public Employee Employee { get; init; } // navigation
    public Discipline Discipline { get; set; }
    public List&lt;UsState&gt; LicensedStates { get; set; }
}

// Query with auto-JOIN via Include
var eors = await db.Engineers
    .Include(e => e.Employee)
    .Where(e => e.IsActive)
    .ToListAsync();

eor.Employee.DisplayName  // from Employee table
eor.Discipline            // from EOR table</code></pre>
                </div>
            </div>
        </div>

        <p>
            The staleness tradeoff is acceptable because employee metadata (names, emails, titles)
            changes infrequently. Even a 15-minute poll cycle is more than sufficient. For employee data,
            we're talking about 831 active records &mdash; the diff query typically returns 0 rows.
        </p>

        <h2 class="sub-heading">Sync Architecture: Polling + Webhooks</h2>
        <p>
            Two mechanisms keep our local data fresh. Both call the same shared handler &mdash;
            the only difference is what triggers them.
        </p>

        <div class="arch-diagram">
            <div class="arch-box vp">Vantagepoint (DLB-SQL04)</div>
            <div class="arch-flow-row">
                <div class="arch-flow-col">
                    <div class="arch-arrow-down">&darr; <span class="arch-label">data changes</span></div>
                    <div class="arch-box endpoint">MapPost Endpoint</div>
                    <div class="arch-label">Webhook (real-time push)</div>
                </div>
                <div class="arch-flow-col">
                    <div class="arch-arrow-down">&darr; <span class="arch-label">ModDate > lastSync</span></div>
                    <div class="arch-box service">BackgroundService</div>
                    <div class="arch-label">Polling (every 15 min)</div>
                </div>
            </div>
            <div class="arch-arrow-down">&darr; both call the same method</div>
            <div class="arch-box handler">VantagepointSyncHandler</div>
            <div class="arch-sub">SyncEmployeeAsync() &rarr; Upsert to Employee table</div>
            <div class="arch-arrow-down">&darr;</div>
            <div class="arch-box db">Employee Table (localhost)</div>
        </div>

        <div class="detail-grid">
            <div class="detail-card">
                <h3>Polling Service</h3>
                <p>A <code>BackgroundService</code> that runs on startup and then every 15 minutes.
                Queries <code>Vantagepoint_DevOps.dbo.EM</code> for rows where <code>ModDate > lastSyncTime</code>.</p>
                <div class="code-block">
                    <div class="code-label">Three behaviors, one query</div>
                    <pre><code>// lastSyncTime determines what gets pulled:
//   First run (empty table) -> full load (all 831 employees)
//   After restart           -> max LastSynced -> catch up
//   Normal tick             -> 15 min ago -> usually 0 rows

var lastSync = await syncHandler.GetLastSyncTimeAsync();

SELECT Employee, FirstName, LastName, PreferredName, EMail, Title
FROM dbo.EM
WHERE Status = 'A' AND ModDate > @@lastSyncTime
ORDER BY ModDate DESC</code></pre>
                </div>
                <div class="code-block">
                    <div class="code-label">Registration in Program.cs</div>
                    <pre><code>builder.Services.AddSingleton&lt;VantagepointSyncHandler&gt;();
builder.Services.AddHostedService&lt;VantagepointPollingService&gt;();</code></pre>
                </div>
            </div>

            <div class="detail-card">
                <h3>Webhook Endpoint</h3>
                <p>Vantagepoint fires webhooks via Application Workflows
                (Settings &gt; Workflow). When an employee changes, VP POSTs to our endpoint.</p>
                <div class="code-block">
                    <div class="code-label">The entire webhook receiver</div>
                    <pre><code>app.MapPost("/api/vp-webhook/employee", async (
    VantagepointWebhookPayload payload,
    VantagepointSyncHandler syncHandler) =>
{
    var employee = new VantagepointSyncHandler
        .VantagepointEmployee(
            EmployeeId: payload.Employee,
            FirstName: payload.FirstName ?? "",
            LastName: payload.LastName ?? "",
            PreferredName: payload.PreferredName ?? "",
            Email: payload.EMail ?? "",
            Title: payload.Title ?? "");

    await syncHandler.SyncEmployeeAsync(employee);
    return Results.Ok(new { status = "synced" });
});</code></pre>
                </div>
                <p class="text-muted text-sm" style="margin-top: 10px">
                    Note: Deltek is deprecating SOAP web services by 2026 and pushing everyone
                    to REST API + webhooks. This approach is aligned with where Vantagepoint is headed.
                </p>
            </div>
        </div>
    </section>

    <section class="doc-section">
        <h1 class="section-heading">Why EF Core Over Dapper + Stored Procedures</h1>
        <p class="section-desc">
            Side-by-side comparisons of the same operations in both approaches.
            The code on the left follows the patterns in ResourcePlanningv3. The code on the right
            is what this project uses.
        </p>

        <h2 class="sub-heading">Reading Data</h2>
        <div class="code-comparison">
            <div class="code-side dapper">
                <div class="code-side-label">Dapper + Stored Procedure</div>
                <pre><code>// 1. Define the stored procedure constant
public static class StoredProcedures
{
    public const string EOR_Read =
        "ProjectManagement_EOR_Read";
}

// 2. Define the entity with SP mapping
[Procedure("ProjectManagement_EOR_Read")]
public class EorEntity : FilterableEntity
{
    [ProcedureParameter]
    [Filter(Ignore = true)]
    public string FilterSQL { get; set; }

    public string Employee { get; set; }
    public string FirstName { get; set; }
    // ... every column manually mapped
}

// 3. Service method to read
public async Task&lt;IReadOnlyList&lt;EorEntity&gt;&gt;
    GetAllEors(string? filterSql = null)
{
    List&lt;Filter&gt; spParameters = new()
    {
        new() {
            FilterField = nameof(EorEntity.FilterSQL),
            FilterValue = filterSql ?? string.Empty
        }
    };
    IEnumerable&lt;EorEntity&gt; entities =
        await _dataAccess.Read&lt;EorEntity&gt;(
            spParameters);
    return entities?.ToList().AsReadOnly()
        ?? new List&lt;EorEntity&gt;().AsReadOnly();
}

// 4. The stored procedure itself (in database)
CREATE PROCEDURE ProjectManagement_EOR_Read
    @@FilterSQL NVARCHAR(MAX) = ''
AS
BEGIN
    SELECT e.*, vp.FirstName, vp.LastName ...
    FROM dbo.EngineerOfRecord e
    LEFT JOIN Vantagepoint_DevOps.dbo.EM vp
        ON e.VantagepointEmployeeId = vp.Employee
    WHERE 1=1
    -- dynamic filter appended via sp_executesql
END</code></pre>
            </div>
            <div class="code-side efcore">
                <div class="code-side-label">EF Core</div>
                <pre><code>// That's it.
var eors = await db.Engineers
    .Include(e => e.Employee)
    .Where(e => e.IsActive)
    .OrderBy(e => e.Employee.LastName)
    .ToListAsync();</code></pre>
                <div class="efcore-benefits">
                    <div class="benefit-item">Strongly typed &mdash; compile-time checked</div>
                    <div class="benefit-item">Parameterized &mdash; SQL injection safe</div>
                    <div class="benefit-item">No stored procedure to maintain</div>
                    <div class="benefit-item">No parameter dictionary to construct</div>
                    <div class="benefit-item">No FilterableEntity base class needed</div>
                </div>
                <details class="filter-examples">
                    <summary>More query examples</summary>
                    <pre><code>// Filter by discipline
var electrical = await db.Engineers
    .Include(e => e.Employee)
    .Where(e => e.Discipline == Discipline.Electrical)
    .ToListAsync();

// Filter by licensed state
var californiaEors = await db.Engineers
    .Where(e => e.LicensedStates.Contains(UsState.CA))
    .ToListAsync();

// Search by employee name
var results = await db.Engineers
    .Include(e => e.Employee)
    .Where(e => e.Employee.LastName.Contains(search))
    .ToListAsync();</code></pre>
                </details>
            </div>
        </div>

        <h2 class="sub-heading">Creating a Record</h2>
        <div class="code-comparison">
            <div class="code-side dapper">
                <div class="code-side-label">Dapper + Stored Procedure</div>
                <pre><code>// Service method
