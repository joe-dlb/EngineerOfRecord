    };
    await _dataStore.Read&lt;EorEntity&gt;(
        "ProjectManagement_EOR_UpdateOrInsert",
        parameters);
}

// Plus the stored procedure:
CREATE PROCEDURE
    ProjectManagement_EOR_UpdateOrInsert
    @@VantagepointEmployeeId NVARCHAR(6),
    @@Discipline NVARCHAR(20),
    @@LicenseExpiration DATETIME2,
    @@IsActive BIT,
    @@LicensedStates NVARCHAR(MAX),
    @@LastModifiedBy NVARCHAR(50)
AS
BEGIN
    -- MERGE or IF EXISTS logic
    -- Parse CSV states into rows
    -- Insert/update accordingly
END</code></pre>
            </div>
            <div class="code-side efcore">
                <div class="code-side-label">EF Core</div>
                <pre><code>// Create the entity — just set the FK + domain fields
var eor = new EngineerOfRecord
{
    VantagepointEmployeeId = "001885",
    Discipline = Discipline.Electrical,
    LicenseExpiration = new DateTime(2028, 6, 1),
    IsActive = true,
    LicensedStates = [UsState.NJ, UsState.NY, UsState.PA]
};

db.Engineers.Add(eor);
await db.SaveChangesAsync();

// EFC generates the INSERT, serializes
// the List as JSON ["NJ","NY","PA"],
// uses the Guid from the constructor.
// Employee data comes from the FK.
// No stored procedure. No parameter mapping.</code></pre>
            </div>
        </div>

        <h2 class="sub-heading">Updating a Record</h2>
        <div class="code-comparison">
            <div class="code-side dapper">
                <div class="code-side-label">Dapper + Stored Procedure</div>
                <pre><code>// Must pass ALL fields — SP doesn't know
// which ones changed
public async Task UpdateEorAsync(
    Guid id, string discipline,
    DateTime expiration, bool isActive,
    string states)
{
    var parameters = new
    {
        Id = id,
        Discipline = discipline,
        LicenseExpiration = expiration,
        IsActive = isActive,
        LicensedStates = states,
        LastModifiedBy = username
    };
    var result = await _dataStore.Execute(
        "ProjectManagement_EOR_Update",
        parameters);
    return result > 0;
}

// Plus maintain the UPDATE stored procedure</code></pre>
            </div>
            <div class="code-side efcore">
                <div class="code-side-label">EF Core</div>
                <pre><code>// Load the entity — EFC starts tracking it
var eor = await db.Engineers.FindAsync(id);

// Change only what changed
eor.Discipline = Discipline.Multi;
eor.LicensedStates.Add(UsState.CT);

// Save — EFC detects what changed and generates
// an UPDATE with ONLY the modified columns
await db.SaveChangesAsync();

// Generated SQL:
// UPDATE [EngineerOfRecord]
// SET [Discipline] = 'Multi',
//     [LicensedStates] = '["NJ","NY","PA","CT"]'
// WHERE [Id] = @@p0
//
// Notice: only Discipline and LicensedStates
// are in the SET clause. EFC's change tracker
// knows the other fields didn't change.</code></pre>
            </div>
        </div>

        <h2 class="sub-heading">Schema Changes</h2>
        <div class="code-comparison">
            <div class="code-side dapper">
                <div class="code-side-label">Dapper + Database Project</div>
                <pre><code>// 1. Add column to database project table def
// 2. Update EVERY stored procedure that touches
//    this table (Read, Insert, Update, Delete)
// 3. Update the C# entity class
// 4. Update parameter dictionaries in services
// 5. Build the DACPAC
// 6. Deploy the DACPAC to dev
// 7. Deploy the DACPAC to staging
// 8. Deploy the DACPAC to production
// 9. Hope the SP changes and DACPAC deploy
//    happen in the right order

// Typical flow for adding one column:
// ~5 files changed across 2 projects</code></pre>
            </div>
            <div class="code-side efcore">
                <div class="code-side-label">EF Core Migrations</div>
                <pre><code>// 1. Add property to C# entity
public string PhoneNumber { get; set; }

// 2. Generate migration (one command)
dotnet ef migrations add AddPhoneNumber

// 3. Auto-generated migration:
migrationBuilder.AddColumn&lt;string&gt;(
    name: "PhoneNumber",
    table: "EngineerOfRecord",
    type: "nvarchar(max)",
    nullable: true);

// 4. Apply (or auto-apply on startup)
dotnet ef database update

// 1 file changed. Migration is versioned in git.
// Rollback: dotnet ef database update PreviousMigration
// The schema IS the code.</code></pre>
            </div>
        </div>

        <h2 class="sub-heading">The Deeper Point: Eliminating the Glue Layer</h2>
        <p>
            Zero stored procedures is the headline. But the deeper benefit is the elimination
            of the entire connector layer between C# and SQL that a Dapper + SP approach requires.
        </p>

        <div class="detail-grid" style="margin: 16px 0 32px">
            <div class="detail-card">
                <h3>1. Parallel Maintenance</h3>
                <p>
                    Every stored procedure has a shadow in C# &mdash; parameter objects, mapping classes,
                    procedure name constants. Change a column and you're updating two places.
                    In our existing projects, <code>StoredProcedures.cs</code> alone is 579 lines of constants.
                    Every service method constructs parameter dictionaries. Entity classes are decorated with
                    <code>[Procedure]</code> and <code>[ProcedureParameter]</code> attributes just to wire
                    the two worlds together. EF Core eliminates that entire connector layer.
                </p>
            </div>
            <div class="detail-card">
                <h3>2. Deployment Coordination</h3>
                <p>
                    SP changes need database deployments (DACPACs). Schema changes need to land
                    <em>before</em> the code that uses them. That ordering constraint creates release friction
                    and is a source of deployment failures. With EF Core Migrations, schema and code ship
                    together &mdash; one <code>dotnet ef database update</code> or auto-migrate on startup, done.
                </p>
            </div>
            <div class="detail-card">
                <h3>3. Discoverability</h3>
                <p>
                    To understand how a record is saved in the Dapper approach: find the service &rarr;
                    see it calls <code>"ProjectManagement_Materials_UpdateOrInsert"</code> &rarr;
                    open SSMS or the Database project &rarr; find that SP &rarr; read the SQL.
                    With EF Core, the entire operation is visible in C# &mdash; the what, the where,
                    and the how are in one place.
                </p>
            </div>
            <div class="detail-card">
                <h3>4. Polling Checks Diffs, Not Full Tables</h3>
                <p>
                    The Vantagepoint sync service uses <code>ModDate > lastSyncTime</code> to pull only
                    changed records. Out of 831 active employees, a typical poll returns 0&ndash;3 rows.
                    On first run, it does a full load. After that, it's incremental. No full table scans,
                    no expensive comparisons. The sync is practically free.
                </p>
            </div>
        </div>

        <p>
            It's not just fewer SQL files &mdash; it's the elimination of the entire glue layer
            between C# and SQL. That's where the real code reduction and bug reduction comes from.
        </p>

        <h2 class="sub-heading">A Note on Long-Term Risk</h2>
        <div class="summary-note" style="margin-bottom: 24px; border-left: 3px solid var(--amber);">
            <p>
                Deltek has officially announced that <strong>SOAP-based web services will be deprecated by 2026</strong>
                and is pushing all integrations to REST API + webhooks. Projects that currently hit Vantagepoint
                via linked servers and cross-database JOINs in stored procedures are relying on a database-level
                integration path that Deltek is moving away from.
            </p>
            <p>
                This project's approach &mdash; a local Employee table synced via REST API polling and webhooks &mdash;
                is aligned with where Deltek is headed. The sync service is the only component that touches Vantagepoint,
                and it can be swapped from direct SQL to REST API calls without changing anything else in the application.
            </p>
        </div>

        <h2 class="sub-heading">The Bottom Line</h2>
        <div class="summary-grid">
            <div class="summary-item">
                <div class="summary-num">0</div>
                <div class="summary-label">Stored procedures to maintain</div>
            </div>
            <div class="summary-item">
                <div class="summary-num">0</div>
                <div class="summary-label">DACPAC deployments</div>
            </div>
            <div class="summary-item">
                <div class="summary-num">1</div>
                <div class="summary-label">Line to query filtered data</div>
            </div>
            <div class="summary-item">
                <div class="summary-num">1</div>
                <div class="summary-label">Command to update schema</div>
            </div>
        </div>

        <div class="summary-note">
            <p>
                EF Core is not a replacement for Dapper in all cases. Complex pivot queries, dynamic SQL reports,
                and high-performance bulk operations may still benefit from raw SQL or Dapper.
                EFC supports <code>FromSqlRaw()</code> for those cases &mdash; you can escape to raw SQL when needed
                without abandoning the framework.
            </p>
            <p>
                For this project &mdash; a greenfield CRUD application with a simple domain model, standard relational
                data, and cross-database sync requirements &mdash; EF Core eliminates entire categories of boilerplate
                and lets us focus on the business logic instead of the plumbing.
            </p>
        </div>
    </section>

</div>

@code {
    private List<Domain.EngineerOfRecord> engineers = [];
    private List<Domain.EngineerOfRecord> filteredEngineers = [];
    private List<Employee> availableEmployees = [];

    // Filters
    private string filterDiscipline = "";
    private string filterState = "";
    private string filterActive = "";

    // Modal state
    private bool showModal;
    private bool isEditing;
    private Guid? editingId;
    private EorForm form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEngineers();
    }

    // ── Data access: every operation creates a short-lived DbContext ──

    private async Task LoadEngineers()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        // Include(e => e.Employee) — EFC auto-JOINs the Employee table.
        // This is one of the key advantages over Dapper: navigation properties.
        engineers = await db.Engineers
            .Include(e => e.Employee)
            .OrderBy(e => e.Employee.LastName)
            .ToListAsync();

        ApplyFilters();
    }

    private async Task LoadAvailableEmployees()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        // Get employee IDs already registered as EORs
        var existingIds = await db.Engineers
            .Select(e => e.VantagepointEmployeeId)
            .ToListAsync();

        // Show only employees not yet registered
        availableEmployees = await db.Employees
            .Where(e => !existingIds.Contains(e.VantagepointEmployeeId))
            .OrderBy(e => e.LastName)
            .ThenBy(e => e.FirstName)
            .ToListAsync();
    }

    private async Task SaveEor()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        if (isEditing && editingId.HasValue)
        {
            var eor = await db.Engineers.FindAsync(editingId.Value);
            if (eor is null) return;

            eor.Discipline = form.Discipline;
            eor.LicenseExpiration = form.LicenseExpiration;
            eor.IsActive = form.IsActive;
            eor.LicensedStates = [.. form.SelectedStates];
        }
        else
        {
            if (string.IsNullOrEmpty(form.SelectedEmployeeId)) return;

            var eor = new Domain.EngineerOfRecord
            {
                VantagepointEmployeeId = form.SelectedEmployeeId,
                Discipline = form.Discipline,
                LicenseExpiration = form.LicenseExpiration,
                IsActive = form.IsActive,
                LicensedStates = [.. form.SelectedStates]
            };
            db.Engineers.Add(eor);
        }

        await db.SaveChangesAsync();
        CloseModal();
        await LoadEngineers();
    }

    private async Task DeleteEor(Domain.EngineerOfRecord eor)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        await db.Engineers.Where(e => e.Id == eor.Id).ExecuteDeleteAsync();
        await LoadEngineers();
    }

    // ── Filters ──

    private void ApplyFilters()
    {
        var list = engineers.AsEnumerable();

        if (Enum.TryParse<Discipline>(filterDiscipline, out var disc))
            list = list.Where(e => e.Discipline == disc);

        if (Enum.TryParse<UsState>(filterState, out var state))
            list = list.Where(e => e.LicensedStates.Contains(state));

        if (filterActive == "active")
            list = list.Where(e => e.IsActive);
        else if (filterActive == "inactive")
            list = list.Where(e => !e.IsActive);

        filteredEngineers = list.ToList();
    }

    private void ClearFilters()
    {
        filterDiscipline = "";
        filterState = "";
        filterActive = "";
        ApplyFilters();
    }

    // ── Modal helpers ──

    private async Task OpenAddModal()
    {
        isEditing = false;
        editingId = null;
        form = new EorForm { LicenseExpiration = DateTime.Today.AddYears(2), IsActive = true };
        await LoadAvailableEmployees();
        showModal = true;
    }

    private void OpenEditModal(Domain.EngineerOfRecord eor)
    {
        isEditing = true;
        editingId = eor.Id;
        form = new EorForm
        {
            SelectedEmployeeId = eor.VantagepointEmployeeId,
            EmployeeDisplay = eor.Employee.DisplayName,
            Discipline = eor.Discipline,
            LicenseExpiration = eor.LicenseExpiration,
            IsActive = eor.IsActive,
            SelectedStates = [.. eor.LicensedStates]
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private void ToggleState(UsState state, bool isChecked)
    {
        if (isChecked && !form.SelectedStates.Contains(state)) form.SelectedStates.Add(state);
        else if (!isChecked) form.SelectedStates.Remove(state);
    }

    // ── Display helpers ──

    private static string Initials(Employee emp)
    {
        var first = string.IsNullOrEmpty(emp.FirstName) ? "" : emp.FirstName[..1];
        var last = string.IsNullOrEmpty(emp.LastName) ? "" : emp.LastName[..1];
        return $"{first}{last}".ToUpper();
    }

    private static string AvatarClass(Discipline d) => d switch
    {
        Discipline.Electrical => "av-blue",
        Discipline.Mechanical => "av-green",
        Discipline.Multi => "av-purple",
        _ => "av-blue"
    };

    private static string BadgeClass(Discipline d) => d switch
    {
        Discipline.Electrical => "badge-blue",
        Discipline.Mechanical => "badge-green",
        Discipline.Multi => "badge-purple",
        _ => "badge-blue"
    };

    // ── Form model ──

    private class EorForm
    {
        public string SelectedEmployeeId { get; set; } = "";
        public string EmployeeDisplay { get; set; } = "";
        public Discipline Discipline { get; set; }
        public DateTime LicenseExpiration { get; set; } = DateTime.Today.AddYears(2);
        public bool IsActive { get; set; } = true;
        public List<UsState> SelectedStates { get; set; } = [];
    }
}
