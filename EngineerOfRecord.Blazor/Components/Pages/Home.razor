@page "/"
@inject IDbContextFactory<EorDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>EOR Registry</PageTitle>

<!-- Stats -->
<div class="stats-row">
    <div class="stat-card">
        <div class="stat-val">@engineers.Count</div>
        <div class="stat-label">Total EORs</div>
    </div>
    <div class="stat-card">
        <div class="stat-val">@engineers.Count(e => e.IsActive)</div>
        <div class="stat-label">Active</div>
    </div>
    <div class="stat-card">
        <div class="stat-val" style="color: var(--red)">@engineers.Count(e => e.IsLicenseExpired)</div>
        <div class="stat-label">Expired Licenses</div>
    </div>
</div>

<!-- Header + Filters -->
<div class="section-row">
    <div class="section-title">
        EOR Registry
        <span style="color: var(--text3); font-weight: 400; font-size: 13px">(@filteredEngineers.Count)</span>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ Add EOR</button>
</div>

<div class="filter-bar">
    <select class="form-select" @bind="filterDiscipline" @bind:after="ApplyFilters">
        <option value="">All Disciplines</option>
        @foreach (var d in Enum.GetValues<Discipline>())
        {
            <option value="@d">@d</option>
        }
    </select>
    <select class="form-select" @bind="filterState" @bind:after="ApplyFilters">
        <option value="">All States</option>
        @foreach (var s in Enum.GetValues<UsState>())
        {
            <option value="@s">@s</option>
        }
    </select>
    <select class="form-select" @bind="filterActive" @bind:after="ApplyFilters">
        <option value="">All Status</option>
        <option value="active">Active Only</option>
        <option value="inactive">Inactive Only</option>
    </select>
    @if (!string.IsNullOrEmpty(filterDiscipline) || !string.IsNullOrEmpty(filterState) || !string.IsNullOrEmpty(filterActive))
    {
        <button class="btn btn-sm" @onclick="ClearFilters">Clear</button>
    }
</div>

<!-- Table -->
<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Discipline</th>
                <th>Licensed States</th>
                <th>License Expires</th>
                <th>Status</th>
                <th style="width: 100px">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (filteredEngineers.Count == 0)
            {
                <tr>
                    <td colspan="6">
                        <div class="empty-state">No EORs found. Add one to get started.</div>
                    </td>
                </tr>
            }
            @foreach (var eor in filteredEngineers)
            {
                <tr>
                    <td>
                        <div style="display: flex; align-items: center; gap: 8px">
                            <div class="avatar @AvatarClass(eor.Discipline)">@Initials(eor.Employee)</div>
                            <div>
                                <div style="font-weight: 500">@eor.Employee.DisplayName</div>
                                <div style="font-size: 11px; color: var(--text3)">@eor.Employee.Title</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge @BadgeClass(eor.Discipline)">@eor.Discipline</span>
                    </td>
                    <td>
                        <div style="display: flex; flex-wrap: wrap; gap: 3px">
                            @foreach (var s in eor.LicensedStates.Order())
                            {
                                <span class="badge badge-gray">@s</span>
                            }
                        </div>
                    </td>
                    <td style="@(eor.IsLicenseExpired ? "color: var(--red); font-weight: 500" : "")">
                        @eor.LicenseExpiration.ToString("MMM d, yyyy")
                        @if (eor.IsLicenseExpired)
                        {
                            <span class="badge badge-red" style="margin-left: 6px">Expired</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(eor.IsActive ? "badge-green" : "badge-gray")">
                            @(eor.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <div style="display: flex; gap: 4px">
                            <button class="btn btn-sm" @onclick="() => OpenEditModal(eor)">Edit</button>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteEor(eor)">Del</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="eor-modal" @onclick:stopPropagation>
            <div class="eor-modal-header">
                <div class="eor-modal-title">@(isEditing ? "Edit EOR" : "Add EOR")</div>
                <button class="btn btn-sm" @onclick="CloseModal">X</button>
            </div>
            <div class="eor-modal-body">
                @if (!isEditing)
                {
                    <div class="form-row">
                        <label class="form-label">Employee (from local VP copy)</label>
                        <select class="form-select" @bind="form.SelectedEmployeeId">
                            <option value="">-- Select an employee --</option>
                            @foreach (var emp in availableEmployees)
                            {
                                <option value="@emp.VantagepointEmployeeId">@emp.DisplayName — @emp.Title</option>
                            }
                        </select>
                    </div>
                }
                else
                {
                    <div class="form-row">
                        <label class="form-label">Employee</label>
                        <input class="form-input" value="@form.EmployeeDisplay" disabled />
                    </div>
                }
                <div class="form-row-2">
                    <div>
                        <label class="form-label">Discipline</label>
                        <select class="form-select" @bind="form.Discipline">
                            @foreach (var d in Enum.GetValues<Discipline>())
                            {
                                <option value="@d">@d</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label">License Expiration</label>
                        <input class="form-input" type="date" @bind="form.LicenseExpiration" />
                    </div>
                </div>
                <div class="form-row-2">
                    <div>
                        <label class="form-label">Status</label>
                        <select class="form-select" @bind="form.IsActive">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                    <div></div>
                </div>
                <div class="form-row">
                    <label class="form-label">Licensed States</label>
                    <div class="states-grid">
                        @foreach (var state in Enum.GetValues<UsState>())
                        {
                            <label class="state-check">
                                <input type="checkbox" checked="@form.SelectedStates.Contains(state)"
                                       @onchange="e => ToggleState(state, (bool)e.Value!)" />
                                @state
                            </label>
                        }
                    </div>
                </div>
            </div>
            <div class="eor-modal-footer">
                <button class="btn" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveEor">
                    @(isEditing ? "Update" : "Add") EOR
                </button>
            </div>
        </div>
    </div>
}

